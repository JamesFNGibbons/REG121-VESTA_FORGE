# Copy to .env in the repository root (used by docker compose).

# Qdrant Cloud
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=reg121_design_brain

# LiteLLM (OpenAI-compatible)
LITELLM_BASE_URL=https://litellm.ai.reg121.com
LITELLM_API_KEY=
LITELLM_INSPECTOR_MODEL=qwen-3.5-32b

# OpenAI (dense embeddings)
OPENAI_API_KEY=

INGEST_BATCH_SIZE=5
INGEST_MAX_RETRIES=3

# Host bind-mount source for your external component library (catalogue.py + HTML).
# Leave unset if you use ./121 library configure (writes .reg121/component_library_root).
# HOST_COMPONENT_LIBRARY=
