# Copy to .env in the repository root (used by docker compose).

# Qdrant Cloud
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=reg121_design_brain

# LiteLLM (OpenAI-compatible: inspector / enrichment chat only)
LITELLM_BASE_URL=https://litellm.ai.reg121.com
LITELLM_API_KEY=
# Must match an exact "id" from GET $LITELLM_BASE_URL/v1/models (with your key). Wrong id → 400 on ingest.
LITELLM_INSPECTOR_MODEL=qwen3-32b

# DeepInfra (OpenAI-compatible: dense embeddings — see https://api.deepinfra.com/v1/openai)
DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
# Must match your embedding model output width (Qwen3-Embedding-4B default is 2560).
DENSE_VECTOR_SIZE=2560

# Forge preprocessor (HTML before enrichment). Default: hyperui. Override with FORGE_DEFAULT_HANDLER=generic for unknown libraries.
FORGE_DEFAULT_HANDLER=hyperui

INGEST_BATCH_SIZE=5
INGEST_MAX_RETRIES=3

# Optional: override the default ./import_bin bind-mount (catalogue.py + HTML).
# HOST_COMPONENT_LIBRARY=
