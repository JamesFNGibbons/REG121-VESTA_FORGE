# Qdrant Cloud
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=reg121_design_brain

# LiteLLM (OpenAI-compatible)
LITELLM_BASE_URL=https://litellm.ai.reg121.com
LITELLM_API_KEY=
LITELLM_INSPECTOR_MODEL=qwen-3.5-32b

# OpenAI (dense embeddings)
OPENAI_API_KEY=

# Ingestion
INGEST_BATCH_SIZE=5
INGEST_MAX_RETRIES=3

# Inside Docker this is set to /library by Compose. On the host, use ./121 library configure
# or set COMPONENT_LIBRARY_ROOT to an absolute path to your external library.
# COMPONENT_LIBRARY_ROOT=
