# Qdrant Cloud
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=reg121_design_brain

# LiteLLM (OpenAI-compatible: inspector / enrichment chat only)
LITELLM_BASE_URL=https://litellm.ai.reg121.com
LITELLM_API_KEY=
LITELLM_INSPECTOR_MODEL=qwen-3.5-32b

# DeepInfra (dense embeddings)
DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
DEEPINFRA_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
# Must match your embedding model output width (Qwen3-Embedding-4B default is 2560).
DENSE_VECTOR_SIZE=2560

# Ingestion
INGEST_BATCH_SIZE=5
INGEST_MAX_RETRIES=3

# Inside Docker the library is mounted at /library (default host path: ./import_bin).
# Override with HOST_COMPONENT_LIBRARY, or run ./121 library configure, or set COMPONENT_LIBRARY_ROOT.
# COMPONENT_LIBRARY_ROOT=
